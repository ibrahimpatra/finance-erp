rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasValidUserId(userId) {
      return request.resource.data.userId == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /incomes/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /expenses/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /spentBy/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /tags/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /transfers/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if false;
      }
      match /ledger/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if false;
      }
      match /auditLogs/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if false;
      }
      match /monthlySnapshots/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /expenseTypes/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /incomeSourceTypes/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
      match /currencies/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserId(userId);
        allow update, delete: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
